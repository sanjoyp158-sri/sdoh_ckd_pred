# Database Configuration
DATABASE_URL=postgresql://ckd_user:ckd_password@localhost:5432/ckd_prediction

# Encryption Key (AES-256)
# Generate a new key using: python3 scripts/generate_encryption_key.py
ENCRYPTION_KEY=your-base64-encoded-256-bit-key-here

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Application Settings
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Security Settings
SECRET_KEY=your-secret-key-for-jwt-tokens
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
