# Application
APP_NAME=SDOH-CKDPred
APP_VERSION=0.1.0
DEBUG=False

# Database
POSTGRES_USER=ckd_user
POSTGRES_PASSWORD=ckd_password
POSTGRES_DB=ckd_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://ckd_user:ckd_password@localhost:5432/ckd_db

# Redis
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Encryption (AES-256 for data at rest - Requirements 13.1)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-encryption-key-change-in-production

# ML Model
MODEL_PATH=models/sdoh_ckdpred_final.json
MODEL_VERSION=1.0.0

# Risk Thresholds (from paper)
RISK_THRESHOLD_HIGH=0.65
RISK_THRESHOLD_MODERATE=0.35

# Performance SLAs
PREDICTION_TIMEOUT_MS=500
SHAP_TIMEOUT_MS=200
INTERVENTION_INITIATION_HOURS=1

# Cost-Effectiveness
TARGET_BCR=3.75
COST_STAGE5_PER_YEAR=89000
COST_STAGE3_PER_YEAR=20000

# Fairness Monitoring
MAX_AUROC_DISPARITY=0.05

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Nginx/TLS Configuration
HTTP_PORT=80
HTTPS_PORT=443
BACKEND_PORT=8000

# Production Settings (for docker-compose.prod.yml)
# Set these in production environment:
# - Generate strong passwords for POSTGRES_PASSWORD and REDIS_PASSWORD
# - Generate SECRET_KEY: openssl rand -hex 32
# - Generate ENCRYPTION_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# - Update CORS_ORIGINS with your production domain
# - Place SSL certificates in nginx/ssl/ directory

